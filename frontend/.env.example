# Même Client ID que GOOGLE_CLIENT_ID côté backend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Même Services ID que APPLE_CLIENT_ID côté backend
VITE_APPLE_CLIENT_ID=com.example.marcheconnect.web

# Production (Render) : URL complète de l'API, ex. https://marcheconnect-api.onrender.com/api
# En dev local, laisser vide (proxy Vite sur /api)
VITE_API_URL=
