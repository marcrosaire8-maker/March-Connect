MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=marches_publics_ouest
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Africa/Porto-Novo
# Mettre > 0 pour tester le scheduler (ex: 5 = toutes les 5 secondes)
SCHEDULER_TEST_INTERVAL_SECONDS=0
# Collecte automatique des offres (minutes) — 30 = toutes les 30 minutes
SCRAPE_INTERVAL_MINUTES=30
# Lancer une collecte dès le démarrage du backend
AUTOMATION_STARTUP_RUN=true
# 0 = pas de limite ; le scraper s'arrête seul sur page vide ou erreur HTTP 5xx
SENEGAL_MAX_PAGES=0
NOTIFICATION_HOUR=7
NOTIFICATION_MINUTE=0
# Intervalle des alertes email RSS (minutes) — 1 = chaque minute
NOTIFICATION_INTERVAL_MINUTES=1

# Envoi d'emails transactionnels (alertes, mot de passe oublié, etc.)
# Recommandé en dev : Gmail + mot de passe d'application
# https://myaccount.google.com/apppasswords (validation en 2 étapes requise)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=marcrosaire8@gmail.com
SMTP_PASSWORD=
SMTP_FROM=MarchéConnect <marcrosaire8@gmail.com>

# Optionnel : Resend (domaine vérifié requis pour envoyer à n'importe quelle adresse)
RESEND_API_KEY=re_xxxxxxxx
# En mode test Resend (onboarding@resend.dev), seul l'email du compte Resend peut recevoir les mails.
# Pour envoyer à d'autres adresses : vérifier un domaine sur https://resend.com/domains
# puis utiliser RESEND_FROM_EMAIL=Alertes <alertes@votredomaine.com>
RESEND_FROM_EMAIL=MarchéConnect <onboarding@resend.dev>

# Authentification JWT
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRE_MINUTES=10080

# Compte admin initial (créé au démarrage si absent)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Google Sign-In (OAuth 2.0)
# Console : https://console.cloud.google.com/apis/credentials
# Type : Application Web — origines JS autorisées : http://localhost:5173
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sign in with Apple
# Console : https://developer.apple.com/account/resources/identifiers/list/serviceId
# Services ID — domaines et URLs de retour : http://localhost:5173
APPLE_CLIENT_ID=com.example.marcheconnect.web

# URL du frontend (CORS, liens email, OAuth Apple)
# Production Render : https://marcheconnect-web.onrender.com
FRONTEND_URL=http://localhost:5173
