MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=marches_publics_ouest
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Africa/Porto-Novo
# Mettre > 0 pour tester le scheduler (ex: 5 = toutes les 5 secondes)
SCHEDULER_TEST_INTERVAL_SECONDS=0
# Collecte automatique des offres (minutes) — 30 = toutes les 30 minutes
SCRAPE_INTERVAL_MINUTES=30
# Lancer une collecte dès le démarrage du backend
AUTOMATION_STARTUP_RUN=true
# 0 = pas de limite ; le scraper s'arrête seul sur page vide ou erreur HTTP 5xx
SENEGAL_MAX_PAGES=0
NOTIFICATION_HOUR=18
NOTIFICATION_MINUTE=15
# Intervalle des alertes email RSS (minutes) — 15 = toutes les 15 minutes
NOTIFICATION_INTERVAL_MINUTES=15
# Nombre maximal d'offres envoyées à chaque utilisateur actif par passage
NOTIFICATION_MAX_OFFRES_PER_EMAIL=1

# Envoi d'emails transactionnels (alertes, mot de passe oublié, etc.)
# Production recommandée : Brevo SMTP — https://www.brevo.com
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=votre-login-smtp-brevo
#   SMTP_PASSWORD=votre-cle-smtp-brevo
#   SMTP_FROM=MarchéConnect <votre-email-verifie@example.com>
# Sans domaine personnalisé : vérifiez un expéditeur unique dans Brevo (Senders → Add sender).
# Dev local : Gmail + mot de passe d'application — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alertes@votredomaine.com
SMTP_PASSWORD=
SMTP_FROM=MarchéConnect <alertes@votredomaine.com>

# Authentification JWT
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRE_MINUTES=10080

# Compte admin initial (créé au démarrage si absent)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Google Sign-In (OAuth 2.0)
# Console : https://console.cloud.google.com/apis/credentials
# Type : Application Web
# Origines JS autorisées (dev + prod) :
#   http://localhost:5173
#   http://127.0.0.1:5173
#   https://marcheconnect-web.onrender.com
# URI de redirection autorisés : même URL que le frontend en prod
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sign in with Apple
# Console : https://developer.apple.com/account/resources/identifiers/list/serviceId
# Services ID — domaines et URLs de retour : http://localhost:5173
APPLE_CLIENT_ID=com.example.marcheconnect.web

# URL du frontend (CORS, liens email, OAuth Apple)
# Production Render : https://marcheconnect-web.onrender.com
FRONTEND_URL=http://localhost:5173
